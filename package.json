{
  "name": "susi-air-pilot-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,vue,scss,json,md}\""
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/fonts": "^0.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@storybook/vue3": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "sass": "^1.81.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  }
}
